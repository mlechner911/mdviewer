{
  "$schema": "https://wails.io/schemas/config.v2.json",
  "name": "marksafe",
  "outputfilename": "marksafe",
  "frontend:install": "npm install",
  "frontend:build": "npm run build",
  "frontend:dev:watcher": "npm run dev",
  "frontend:dev:serverUrl": "http://localhost:34116",
  "devserver": "127.0.0.1:34117",
  "author": {
    "name": "Michael Lechner",
    "email": "xsltwonder@gmail.com"
  },
  "info": {
    "companyName": "Michael Lechner",
    "productName": "MarkSafe",
    "productVersion": "1.2.2",
    "copyright": "Copyright 2026 Michael Lechner",
    "comments": "An easy to use cross platform Markdown viewer."
  },
  "fileAssociations": [
    {
      "ext": "md",
      "name": "Markdown File",
      "description": "Markdown formatted text file",
      "iconName": "appicon",
      "role": "Editor"
    },
    {
      "ext": "markdown",
      "name": "Markdown File",
      "description": "Markdown formatted text file",
      "iconName": "appicon",
      "role": "Editor"
    },
    {
      "ext": "mdown",
      "name": "Markdown File",
      "description": "Markdown formatted text file",
      "iconName": "appicon",
      "role": "Editor"
    }
  ],
  "windows": {
    "nsis": {
      "customMessages": "",
      "compression": "lzma",
      "include": ""
    }
  }
}
